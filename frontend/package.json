{
  "name": "my-stock-map-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "deploy": "npm run type-check && vite build --base=/my-stock-map/ && gh-pages -d dist",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "format:check": "prettier . --check",
    "type-check": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "check": "npm run format:check && npm run lint && npm run type-check",
    "check:strict": "npm run format:check && npm run lint:strict && npm run type-check"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "pinia": "^3.0.3",
    "vue": "^3.5.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.7.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "npm:rolldown-vite@7.1.14",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.2.2"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.1.14"
  }
}
