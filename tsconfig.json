{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true,
    "skipLibCheck": false,
    "noUncheckedIndexedAccess": true,

    "types": ["vite/client"],

    "target": "ES2022",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "vite-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ]
}
